WEB_PORT=8080
DOCKER_WEB_PORT=85

WEBSOCKET_PORT=8081
DOCKER_WEBSOCKET_PORT=86

# Secret used by Kick/VK Play/W.TV chat adapters to publish messages into OBS overlays.
# Generate a long random value; never expose it in the browser or OBS URL.
OVERLAY_INGEST_TOKEN=

# Admin panel. Generate long random values, for example: openssl rand -hex 32
ADMIN_SESSION_SECRET=
ADMIN_CREDENTIALS_ENCRYPTION_KEY=

# DonationAlerts Socket.IO is subscribed to server-side. Tokens are entered in /admin/settings.
DONATIONALERTS_SOCKET_URL=https://socket10.donationalerts.com

# Required only for scheduled MemeAlerts stickers. MEMEALERTS_JWT remains below.
MEMEALERTS_CHANNEL_ID=

# Таймзона для отображения дат/времени в интерфейсе и логах.
# По умолчанию Europe/Minsk (UTC+3). Список: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Minsk
TZ_DISPLAY=Europe/Minsk

MONGO_USERNAME=root
MONGO_PASSWORD=root
MONGO_PORT=27017
MONGO_DB=twitch_bot
MONGO_HOSTNAME=db

BOT_NAME= # your bot nickname on twitch
CHANNEL= # your channel name
OAUTH_TOKEN= # you can get a token here: https://twitchapps.com/tmi/
DEBUG=true
GOOGLE_SPEECH_API_TOKEN=

TWITCH_API_CLIENT_ID=
TWITCH_API_CLIENT_SECRET=
TWITCH_ACCESS_TOKEN=
BROADCASTER_ID=
MODERATOR_ID=

TROVO_BOT_EMAIL=
TROVO_BOT_PASSWORD=
TROVO_CHANNEL=

OPENAI_API_KEY=
# Supported: openrouter, gpt-5-nano (alias: gpt-5.4-nano), gpt-4o-mini, gpt-4o, gpt-4-turbo, gpt-3.5-turbo-1106, gpt-3.5-turbo, deepseek, pawan, text-davinci-003
CHAT_GPT_MODEL=gpt-3.5-turbo
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_HTTP_REFERER=
OPENROUTER_TITLE=
PAWAN_API_KEY=
DEEPSEEK_API_KEY=

POINTAUC_TOKEN=

MEMEALERTS_JWT=
MEMEALERTS_HOST=

# Twitch Custom Reward ID for "Спалить мемера"
TWITCH_REWARD_BURN_MEMER_ID=

# Twitch Custom Reward ID for "Случайный мем"
TWITCH_REWARD_RANDOM_MEME_ID=

# Twitch Custom Reward ID for "Случайный аудио-мем"
TWITCH_REWARD_RANDOM_AUDIO_MEME_ID=
