<section class="admin-page"><div class="admin-page__heading"><div><div class="eyebrow">Автоматизация</div><h1>Мемы по расписанию</h1></div></div>{{#if success}}<p class="form-notice form-notice--success">{{success}}</p>{{/if}}{{#if error}}<p class="form-notice form-notice--error">{{error}}</p>{{/if}}
<div class="admin-grid"><article class="admin-card"><h2>Новая серия мемов</h2><p class="admin-card__hint">Можно запланировать сразу несколько отправок. При выборе случайного режима мем выбирается из каталога канала стримера и статического списка legacy-мемов.</p>{{#if memeCatalogError}}<p class="form-notice form-notice--error">Каталог сейчас недоступен: {{memeCatalogError}}. Случайный режим всё равно можно поставить в очередь.</p>{{/if}}<form method="post" action="/admin/memes" class="admin-form"><input type="hidden" name="_csrf" value="{{csrfToken}}" /><label>Отправитель<select name="sender"><option value="test">Тестовый пользователь</option><option value="owner">Владелец канала</option></select></label><label>Режим<select name="selection"><option value="random">Случайный мем из каталога</option><option value="sticker">Конкретный мем</option></select></label><label>Мем из каталога{{#if hasMemeOptions}}<select name="stickerId"><option value="">— не выбирать для случайного режима —</option>{{#each memeOptions}}<option value="{{id}}">{{name}} ({{id}})</option>{{/each}}</select>{{else}}<input name="stickerId" placeholder="Можно указать ID вручную" />{{/if}}</label><div class="admin-form__columns"><label>Количество<input name="quantity" type="number" min="1" max="200" value="1" required /></label><label>Интервал, минут<input name="intervalMinutes" type="number" min="1" max="1440" value="5" required /></label></div><label>Сообщение<textarea name="message" maxlength="255"></textarea></label><label class="admin-check"><input name="isSoundOnly" type="checkbox" /> Только звук</label><label>Первая дата и время<input name="scheduledFor" type="datetime-local" value="{{defaultScheduledFor}}" required /></label><button class="btn btn--primary" type="submit">Поставить серию в расписание</button></form></article>
<article class="admin-card"><h2>Очередь</h2>{{#if hasScheduledMemes}}<div class="admin-list">{{#each scheduledMemes}}<div class="admin-list__row"><div><strong>{{selectionLabel}}</strong><span>{{senderLabel}} · {{message}}</span>{{#if errorLabel}}<span class="form-notice--error">Ошибка: {{errorLabel}}</span>{{/if}}</div><div><strong>{{scheduledForLabel}}</strong><span>{{status}}</span>{{#if (eq status 'pending')}}<form method="post" action="/admin/memes/{{_id}}/cancel"><input type="hidden" name="_csrf" value="{{../csrfToken}}" /><button class="admin-link-button" type="submit">Отменить</button></form>{{/if}}</div></div>{{/each}}</div>{{else}}<p class="empty-state">Очередь пуста.</p>{{/if}}</article></div></section>
