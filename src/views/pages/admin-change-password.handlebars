<section class="admin-page admin-page--narrow">
  <div class="admin-page__heading"><div><div class="eyebrow">Безопасность</div><h1>Смена пароля</h1></div></div>
  {{#if mustChangePassword}}<p class="form-notice form-notice--error">Перед работой в админке необходимо заменить временный пароль.</p>{{/if}}
  {{#if error}}<p class="form-notice form-notice--error">{{error}}</p>{{/if}}
  <article class="admin-card"><form method="post" action="/admin/change-password" class="admin-form"><input type="hidden" name="_csrf" value="{{csrfToken}}" /><label>Новый пароль <small>минимум 12 символов</small><input name="password" type="password" autocomplete="new-password" minlength="12" required /></label><label>Повторите пароль<input name="confirmation" type="password" autocomplete="new-password" minlength="12" required /></label><button class="btn btn--primary" type="submit">Сохранить пароль</button></form></article>
</section>
