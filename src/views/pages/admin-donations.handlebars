<section class="admin-page"><div class="admin-page__heading"><div><div class="eyebrow">Автоматизация</div><h1>Донаты по расписанию</h1></div></div>{{#if success}}<p class="form-notice form-notice--success">{{success}}</p>{{/if}}{{#if error}}<p class="form-notice form-notice--error">{{error}}</p>{{/if}}
<div class="admin-grid"><article class="admin-card"><h2>Новый донат</h2><form method="post" action="/admin/donations" class="admin-form"><input type="hidden" name="_csrf" value="{{csrfToken}}" /><label>Ник<input name="donorName" maxlength="100" required /></label><label>Сумма<input name="amount" type="number" step="0.01" min="0.01" required /></label><label>Валюта<input name="currency" value="RUB" maxlength="8" /></label><label>Сообщение<textarea name="message" maxlength="255"></textarea></label><label>Дата и время<input name="scheduledFor" type="datetime-local" value="{{defaultScheduledFor}}" required /></label><button class="btn btn--primary" type="submit">Поставить в расписание</button></form></article>
<article class="admin-card"><h2>Очередь</h2>{{#if hasScheduledDonations}}<div class="admin-list">{{#each scheduledDonations}}<div class="admin-list__row"><div><strong>{{donorName}} · {{amountLabel}}</strong><span>{{message}}</span>{{#if errorLabel}}<span class="form-notice--error">Ошибка: {{errorLabel}}</span>{{/if}}</div><div><strong>{{scheduledForLabel}}</strong><span>{{status}}</span>{{#if (or (eq status 'pending') (eq status 'failed'))}}<form method="post" action="/admin/donations/{{_id}}/send-now"><input type="hidden" name="_csrf" value="{{../csrfToken}}" /><button class="admin-link-button" type="submit">Отправить сейчас</button></form>{{/if}}{{#if (eq status 'pending')}}<form method="post" action="/admin/donations/{{_id}}/cancel"><input type="hidden" name="_csrf" value="{{../csrfToken}}" /><button class="admin-link-button" type="submit">Отменить</button></form>{{/if}}</div></div>{{/each}}</div>{{else}}<p class="empty-state">Очередь пуста.</p>{{/if}}</article></div></section>
