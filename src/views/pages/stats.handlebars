{{! ── Page intro ── }}
<section class="container section-spacing stats-page-intro">
  <div class="section-heading">
    <div>
      <div class="eyebrow">Подробная аналитика</div>
      <h1>Статистика канала {{profile.name}}</h1>
    </div>
    <button class="button button--ghost button--small" type="button" data-refresh-page>
      ↻ Обновить
    </button>
  </div>

  <p class="section-description">
    Расширенная статистика стримов, чата и мемов. Данные обновляются автоматически.
  </p>
</section>

{{! ── Filters ── }}
<section class="container section-spacing">
  <form class="stats-filters" method="get" action="/stats">
    <div class="stats-filters__group">
      <label class="stats-filters__label" for="filter-stream">Стрим</label>
      <select class="stats-filters__select" name="stream" id="filter-stream">
        <option value="">Все стримы</option>
        {{#each streamSessions.streams}}
          <option value="{{id}}" {{#if (eq ../filters.streamId (toString id))}}selected{{/if}}>
            {{dateLabel}} — {{title}}
          </option>
        {{/each}}
      </select>
    </div>

    <div class="stats-filters__group">
      <label class="stats-filters__label" for="filter-chatter">Чаттер</label>
      <input
        class="stats-filters__input"
        type="text"
        name="chatter"
        id="filter-chatter"
        placeholder="Введите ник..."
        value="{{filters.chatter}}"
      >
    </div>

    <button class="button button--primary button--small" type="submit">Применить</button>

    {{#if (or filters.streamId filters.chatter)}}
      <a href="/stats" class="button button--ghost button--small">Сбросить</a>
    {{/if}}
  </form>
</section>

{{! ── Tab navigation ── }}
<section class="container section-spacing">
  <div class="stats-tabs" data-stats-tabs>
    <button class="stats-tabs__btn{{#unless filters.chatter}} is-active{{/unless}}" data-tab="overview">📊 Обзор</button>
    <button class="stats-tabs__btn" data-tab="streams">🎬 Стримы</button>
    <button class="stats-tabs__btn{{#if filters.chatter}} is-active{{/if}}" data-tab="chatters">💬 Чаттеры</button>
    <button class="stats-tabs__btn" data-tab="memes">🎨 Мемы</button>
    <button class="stats-tabs__btn" data-tab="viewers">👁 Зрители</button>
  </div>
</section>

{{! ── Tab: Overview ── }}
<section class="container section-spacing stats-tab-content{{#unless filters.chatter}} is-active{{/unless}}" data-tab-content="overview">
  <div class="stats-grid stats-grid--dense">
    <article class="stat-card stat-card--primary">
      <span class="stat-card__label">🎬 Всего стримов</span>
      <strong class="stat-card__value">{{overallStats.totalStreamsLabel}}</strong>
      <p class="stat-card__description">Записанных стрим-сессий в базе.</p>
    </article>

    <article class="stat-card stat-card--secondary">
      <span class="stat-card__label">💬 Всего сообщений</span>
      <strong class="stat-card__value">{{overallStats.totalMessagesLabel}}</strong>
      <p class="stat-card__description">Общий объём истории в коллекции chatLog.</p>
    </article>

    <article class="stat-card stat-card--secondary">
      <span class="stat-card__label">👥 Уникальных чаттеров</span>
      <strong class="stat-card__value">{{overallStats.totalUniqueChattersLabel}}</strong>
      <p class="stat-card__description">Пользователей, написавших хотя бы одно сообщение.</p>
    </article>

    <article class="stat-card stat-card--primary">
      <span class="stat-card__label">🎨 Всего мемов</span>
      <strong class="stat-card__value">{{overallStats.totalMemesLabel}}</strong>
      <p class="stat-card__description">Отправлено стикеров через MemeAlerts.</p>
    </article>

    <article class="stat-card stat-card--neutral">
      <span class="stat-card__label">🔥 Пиковый онлайн за всё время</span>
      <strong class="stat-card__value">{{overallStats.peakViewersAllTimeLabel}}</strong>
      <p class="stat-card__description">Максимальное число зрителей на стриме.</p>
    </article>

    <article class="stat-card stat-card--neutral">
      <span class="stat-card__label">⏱ Средняя длительность стрима</span>
      <strong class="stat-card__value">{{overallStats.avgStreamDuration}}</strong>
      <p class="stat-card__description">Среднее время эфира по завершённым стримам.</p>
    </article>
  </div>
</section>

{{! ── Tab: Streams ── }}
<section class="container section-spacing stats-tab-content" data-tab-content="streams">
  <article class="panel-card">
    <div class="panel-card__header">
      <div>
        <div class="eyebrow">История эфиров</div>
        <h2>Последние стримы</h2>
      </div>
    </div>

    {{#if streamSessions.hasStreams}}
      <div class="stats-table-wrap">
        <table class="stats-table">
          <thead>
            <tr>
              <th>Дата</th>
              <th>Название</th>
              <th>Категория</th>
              <th>Статус</th>
              <th>Длительность</th>
              <th>Макс. онлайн</th>
              <th>Средний онлайн</th>
              <th>Сообщений</th>
              <th>Чаттеров</th>
              <th>Мемов</th>
            </tr>
          </thead>
          <tbody>
            {{#each streamSessions.streams}}
              <tr>
                <td><a href="/stats?stream={{id}}">{{dateLabel}}</a></td>
                <td>{{title}}</td>
                <td>{{gameName}}</td>
                <td>
                  {{#eq status 'live'}}
                    <span class="status-badge status-badge--live">Live</span>
                  {{else}}
                    <span class="status-badge status-badge--ended">Завершён</span>
                  {{/eq}}
                </td>
                <td>{{durationLabel}}</td>
                <td>{{maxViewersLabel}}</td>
                <td>{{avgViewersLabel}}</td>
                <td>{{messagesCountLabel}}</td>
                <td>{{uniqueChattersLabel}}</td>
                <td>{{memesCountLabel}}</td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{else}}
      <p class="empty-state">Стрим-сессии появятся после первого записанного эфира.</p>
    {{/if}}
  </article>
</section>

{{! ── Tab: Chatters ── }}
<section class="container section-spacing stats-tab-content{{#if filters.chatter}} is-active{{/if}}" data-tab-content="chatters">
  {{#if chatterStats}}
    {{#if chatterStats.notFound}}
      <article class="panel-card">
        <div class="panel-card__header">
          <div>
            <div class="eyebrow">Профиль чаттера</div>
            <h2>Чаттер не найден</h2>
          </div>
        </div>
        <p class="empty-state">Пользователь <strong>{{chatterStats.searchedUser}}</strong> ещё не написал ни одного сообщения. Проверь правильность написания ника или попробуй найти его в таблице лидеров ниже.</p>
      </article>
    {{else}}
      <div class="chatter-profile">
        <article class="panel-card">
          <div class="panel-card__header">
            <div>
              <div class="eyebrow">Профиль чаттера</div>
              <h2>{{chatterStats.displayName}}</h2>
              <span class="activity-badge activity-badge--{{chatterStats.activityLevelClass}}">{{chatterStats.activityLevel}}</span>
            </div>
            <div class="chatter-rank">
              <span class="chatter-rank__label">Место</span>
              <strong class="chatter-rank__value">{{chatterStats.rankLabel}}</strong>
            </div>
          </div>

          <dl class="detail-list chatter-profile__stats">
            <div>
              <dt>Всего сообщений</dt>
              <dd>{{chatterStats.totalMessagesLabel}}</dd>
            </div>
            <div>
              <dt>Первое сообщение</dt>
              <dd>{{chatterStats.firstMessageAtLabel}}</dd>
            </div>
            <div>
              <dt>Последнее сообщение</dt>
              <dd>{{chatterStats.lastMessageAtLabel}}</dd>
            </div>
            <div>
              <dt>Стримов с участием</dt>
              <dd>{{chatterStats.streamsCountLabel}}</dd>
            </div>
            <div>
              <dt>Примерное время просмотра</dt>
              <dd>{{chatterStats.watchTimeLabel}}</dd>
            </div>
            <div>
              <dt>Срезов просмотра</dt>
              <dd>{{chatterStats.viewerSnapshotCountLabel}}</dd>
            </div>
            {{#if chatterStats.firstSeenAsViewerAtLabel}}
            <div>
              <dt>Впервые замечен</dt>
              <dd>{{chatterStats.firstSeenAsViewerAtLabel}}</dd>
            </div>
            {{/if}}
            {{#if chatterStats.lastSeenAsViewerAtLabel}}
            <div>
              <dt>Последний раз замечен</dt>
              <dd>{{chatterStats.lastSeenAsViewerAtLabel}}</dd>
            </div>
            {{/if}}
            <div>
              <dt>В среднем на стрим</dt>
              <dd>{{chatterStats.avgMessagesPerStreamLabel}}</dd>
            </div>
            {{#if chatterStats.peakHourLabel}}
            <div>
              <dt>Пиковый час</dt>
              <dd>{{chatterStats.peakHourLabel}}</dd>
            </div>
            {{/if}}
            {{#if chatterStats.peakDayLabel}}
            <div>
              <dt>Самый активный день</dt>
              <dd>{{chatterStats.peakDayLabel}}</dd>
            </div>
            {{/if}}
          </dl>

          {{! Activity charts }}
          <div class="chart-section">
            <div class="eyebrow chart-section__title">Активность по часам</div>
            <div class="hourly-chart">
              {{#each chatterStats.hourlyBars}}
                <div class="hourly-chart__bar" style="height: {{barHeight}}%;" title="{{count}} сообщ."></div>
              {{/each}}
            </div>
            <div class="hourly-chart__labels">
              <span>00</span><span>06</span><span>12</span><span>18</span><span>23</span>
            </div>
          </div>

          <div class="chart-section">
            <div class="eyebrow chart-section__title">Активность по дням недели</div>
            <div class="daily-chart">
              {{#each chatterStats.dailyBars}}
                <div class="daily-chart__item">
                  <div class="daily-chart__bar-wrap">
                    <div class="daily-chart__bar" style="height: {{barWidth}}%;" title="{{count}} сообщ."></div>
                  </div>
                  <span class="daily-chart__label">{{dayName}}</span>
                </div>
              {{/each}}
            </div>
          </div>
        </article>

        <article class="panel-card">
          <div class="panel-card__header">
            <div>
              <div class="eyebrow">Последние сообщения</div>
              <h3>{{chatterStats.displayName}}</h3>
            </div>
          </div>

          {{#if chatterStats.hasRecentMessages}}
            <div class="chatter-messages-scroll">
              <ul class="message-list">
                {{#each chatterStats.recentMessages}}
                  <li class="message-item">
                    <div class="message-item__head">
                      <span>{{createdAtLabel}}</span>
                    </div>
                    <p>{{text}}</p>
                  </li>
                {{/each}}
              </ul>
            </div>
          {{else}}
            <p class="empty-state">Сообщения не найдены.</p>
          {{/if}}

          {{#if chatterStats.memeStats}}
            <div class="meme-section">
              <div class="panel-card__header">
                <div>
                  <div class="eyebrow">Мемы</div>
                </div>
                <span class="panel-card__meta">{{chatterStats.memeStats.totalMemesLabel}} всего</span>
              </div>
              <dl class="detail-list">
                <div>
                  <dt>Всего мемов</dt>
                  <dd>{{chatterStats.memeStats.totalMemesLabel}}</dd>
                </div>
                <div>
                  <dt>Первый мем</dt>
                  <dd>{{chatterStats.memeStats.firstMemeAtLabel}}</dd>
                </div>
                <div>
                  <dt>Последний мем</dt>
                  <dd>{{chatterStats.memeStats.lastMemeAtLabel}}</dd>
                </div>
              </dl>

              {{#if chatterStats.memeStats.hasTopMemes}}
                <ol class="leaderboard-list meme-section__list">
                  {{#each chatterStats.memeStats.topMemes}}
                    <li class="leaderboard-item">
                      <span class="leaderboard-item__position">#{{position}}</span>
                      <div class="leaderboard-item__content">
                        <strong>🎨 {{stickerName}}</strong>
                        <span>{{countLabel}} раз</span>
                      </div>
                    </li>
                  {{/each}}
                </ol>
              {{/if}}
            </div>
          {{/if}}
        </article>
      </div>
    {{/if}}
  {{/if}}

  <article class="panel-card leaderboard-section">
    <div class="panel-card__header">
      <div>
        <div class="eyebrow">Таблица лидеров</div>
        <h2>Топ чаттеров</h2>
      </div>
      <span class="panel-card__meta">{{chatStats.source}}</span>
    </div>

    {{#if chatStats.note}}
      <p class="notice notice--warning">{{chatStats.note}}</p>
    {{/if}}

    {{#if chatStats.hasTopChatters}}
      <ol class="leaderboard-list leaderboard-list--large">
        {{#each chatStats.topChatters}}
          <li class="leaderboard-item">
            <span class="leaderboard-item__position">#{{position}}</span>
            <div class="leaderboard-item__content">
              <strong><a href="/stats?chatter={{user}}">{{displayName}}</a></strong>
              <span>{{messagesCountLabel}} сообщений · последнее: {{lastMessageAtLabel}}</span>
            </div>
          </li>
        {{/each}}
      </ol>
    {{else}}
      <p class="empty-state">Пока нет достаточного количества сообщений для построения топа.</p>
    {{/if}}
  </article>
</section>

{{! ── Tab: Memes ── }}
<section class="container section-spacing stats-tab-content" data-tab-content="memes">
  <div class="meme-grid">
    <article class="panel-card">
      <div class="panel-card__header">
        <div>
          <div class="eyebrow">Топ мемеров</div>
          <h2>Самые активные</h2>
        </div>
      </div>

      {{#if memeStats.hasTopMemers}}
        <ol class="leaderboard-list">
          {{#each memeStats.topMemers}}
            <li class="leaderboard-item">
              <span class="leaderboard-item__position">#{{position}}</span>
              <div class="leaderboard-item__content">
                <strong><a href="/stats?chatter={{user}}">{{displayName}}</a></strong>
                <span>{{memesCountLabel}} мемов · последний: {{lastMemeAtLabel}}</span>
              </div>
            </li>
          {{/each}}
        </ol>
      {{else}}
        <p class="empty-state">Мемы ещё не были записаны. Данные появятся после первого опроса MemeAlerts.</p>
      {{/if}}
    </article>

    <article class="panel-card">
      <div class="panel-card__header">
        <div>
          <div class="eyebrow">Популярные мемы</div>
          <h2>Самые используемые</h2>
        </div>
      </div>

      {{#if memeStats.hasTopMemes}}
        <ol class="leaderboard-list">
          {{#each memeStats.topMemes}}
            <li class="leaderboard-item">
              <span class="leaderboard-item__position">#{{position}}</span>
              <div class="leaderboard-item__content">
                <strong>🎨 {{stickerName}}</strong>
                <span>{{usageCountLabel}} раз · последний: {{lastUsedAtLabel}}</span>
              </div>
            </li>
          {{/each}}
        </ol>
      {{else}}
        <p class="empty-state">Данные по мемам появятся после накопления статистики.</p>
      {{/if}}
    </article>
  </div>

  {{#if memeStats.hasRecentMemes}}
    <article class="panel-card leaderboard-section">
      <div class="panel-card__header">
        <div>
          <div class="eyebrow">Последние мемы</div>
          <h2>Лента мемов</h2>
        </div>
        <span class="panel-card__meta">Всего: {{memeStats.totalMemesLabel}}</span>
      </div>

      <ul class="message-list">
        {{#each memeStats.recentMemes}}
          <li class="message-item">
            <div class="message-item__head">
              <strong><a href="/stats?chatter={{user}}">{{displayName}}</a></strong>
              <span>{{sentAtLabel}}</span>
            </div>
            <p>🎨 {{stickerName}}</p>
          </li>
        {{/each}}
      </ul>
    </article>
  {{/if}}
</section>

{{! ── Tab: Viewers ── }}
<section class="container section-spacing stats-tab-content" data-tab-content="viewers">
  <div class="stats-grid stats-grid--dense">
    <article class="stat-card stat-card--primary">
      <span class="stat-card__label">🔥 Пиковый онлайн за 24 часа</span>
      <strong class="stat-card__value">{{viewerStats.peakViewerCount24hLabel}}</strong>
      <p class="stat-card__description">Максимальное число зрителей по сохранённым срезам.</p>
    </article>

    <article class="stat-card stat-card--secondary">
      <span class="stat-card__label">📊 Средний онлайн за 24 часа</span>
      <strong class="stat-card__value">{{viewerStats.averageViewerCount24hLabel}}</strong>
      <p class="stat-card__description">Среднее значение по срезам viewer-лога.</p>
    </article>

    <article class="stat-card stat-card--secondary">
      <span class="stat-card__label">👥 Уникальных зрителей за 24 часа</span>
      <strong class="stat-card__value">{{viewerStats.uniqueViewers24hLabel}}</strong>
      <p class="stat-card__description">Считается по viewer-срезам.</p>
    </article>

    <article class="stat-card stat-card--neutral">
      <span class="stat-card__label">💾 Срезов сохранено</span>
      <strong class="stat-card__value">{{viewerStats.totalSnapshotsLabel}}</strong>
      <p class="stat-card__description">Сколько viewer snapshot документов накоплено.</p>
    </article>
  </div>

  <article class="panel-card leaderboard-section">
    <div class="panel-card__header">
      <div>
        <div class="eyebrow">Тренд аудитории</div>
        <h2>История viewer-срезов</h2>
      </div>
      <span class="panel-card__meta">Последний срез: {{viewerStats.latestViewerCountLabel}}</span>
    </div>

    {{#if viewerStats.note}}
      <p class="notice notice--warning">{{viewerStats.note}}</p>
    {{/if}}

    {{#if viewerStats.hasViewerHistory}}
      <div class="history-list history-list--large">
        {{#each viewerStats.viewerHistory}}
          <div class="history-item">
            <div class="history-item__meta">
              <span>{{label}}</span>
              <strong>{{viewersCountLabel}}</strong>
            </div>
            <div class="history-item__bar">
              <span style="width: {{barWidth}};"></span>
            </div>
          </div>
        {{/each}}
      </div>
    {{else}}
      <p class="empty-state">Как только бот накопит viewer-срезы, здесь появится динамика онлайна.</p>
    {{/if}}
  </article>
</section>

{{! ── JSON API links ── }}
<section class="container section-spacing api-links-grid">
  <article class="panel-card">
    <div class="panel-card__header">
      <div>
        <div class="eyebrow">Интеграции</div>
        <h2>JSON-эндпоинты</h2>
      </div>
    </div>

    <div class="link-grid link-grid--compact">
      <a class="link-card" href="/api/streamer/summary" target="_blank" rel="noreferrer">
        <strong>/api/streamer/summary</strong>
        <span>Краткая сводка по стриму и профилю.</span>
      </a>
      <a class="link-card" href="/api/streamer/stats" target="_blank" rel="noreferrer">
        <strong>/api/streamer/stats</strong>
        <span>Подробные viewer и chat метрики.</span>
      </a>
      <a class="link-card" href="/api/streamer/stats?stream=latest" target="_blank" rel="noreferrer">
        <strong>/api/streamer/stats?stream=...</strong>
        <span>Статистика по конкретному стриму.</span>
      </a>
      <a class="link-card" href="/api/streamer/chatters/nglzzz" target="_blank" rel="noreferrer">
        <strong>/api/streamer/chatters/:user</strong>
        <span>Статистика конкретного чаттера.</span>
      </a>
    </div>
  </article>
</section>

<script>
(function () {
  var tabs = document.querySelectorAll('[data-stats-tabs] [data-tab]');
  var contents = document.querySelectorAll('[data-tab-content]');

  tabs.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var target = btn.getAttribute('data-tab');

      tabs.forEach(function (b) { b.classList.remove('is-active'); });
      contents.forEach(function (c) { c.classList.remove('is-active'); });

      btn.classList.add('is-active');
      var panel = document.querySelector('[data-tab-content="' + target + '"]');
      if (panel) panel.classList.add('is-active');
    });
  });
})();
</script>
