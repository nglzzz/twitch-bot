<section class="admin-page"><div class="admin-page__heading"><div><div class="eyebrow">Доступ</div><h1>Пользователи админки</h1></div></div>{{#if success}}<p class="form-notice form-notice--success">{{success}}</p>{{/if}}{{#if error}}<p class="form-notice form-notice--error">{{error}}</p>{{/if}}
<div class="admin-grid"><article class="admin-card"><h2>Добавить администратора</h2><p class="admin-card__hint">Новый пользователь войдёт с временным паролем <code>{{temporaryPassword}}</code> и сразу задаст собственный.</p><form method="post" action="/admin/users" class="admin-form"><input type="hidden" name="_csrf" value="{{csrfToken}}" /><label>Имя<input name="displayName" maxlength="100" /></label><label>Логин<input name="username" pattern="[A-Za-z0-9_]{3,25}" required /></label><button class="btn btn--primary" type="submit">Добавить</button></form></article>
<article class="admin-card"><h2>Список</h2><div class="admin-list">{{#each users}}<div class="admin-list__row"><div><strong>{{displayName}}</strong><span>{{username}} · создан {{createdAtLabel}}</span></div><div><strong>{{#if isActive}}Активен{{else}}Отключён{{/if}}</strong><span>Вход: {{lastLoginAtLabel}}{{#if mustChangePassword}} · ждёт смены пароля{{/if}}</span>{{#unless isCurrent}}<form method="post" action="/admin/users/{{_id}}/toggle"><input type="hidden" name="_csrf" value="{{../csrfToken}}" /><button class="admin-link-button" type="submit">{{#if isActive}}Отключить{{else}}Включить{{/if}}</button></form>{{/unless}}</div></div>{{/each}}</div></article></div></section>
