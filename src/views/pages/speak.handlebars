<style>
  .speak-page {
    display: flex;
    flex-direction: column;
    height: 100vh;
    max-height: 100vh;
    overflow: hidden;
    margin: -2rem -2rem 0;
  }

  .page-speak .site-main {
    padding: 0;
    max-width: none;
  }

  {{#unless isOverlay}}
  .speak-page {
    height: auto;
    max-height: none;
    min-height: 80vh;
    margin: 0;
  }

  .page-speak .site-main {
    padding: 0 0 1rem 0;
  }
  {{/unless}}

  /* Status bar */
  .speak-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--panel);
    border-bottom: 1px solid var(--panel-border);
    font-size: 0.8rem;
    color: var(--muted);
  }

  .speak-status__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #ef4444;
    transition: background 0.3s;
  }

  .speak-status__dot--connected {
    background: #22c55e;
  }

  /* Controls */
  .speak-controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    padding: 0.6rem 1rem;
    background: var(--surface);
    border-bottom: 1px solid var(--panel-border);
  }

  .speak-controls label {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.78rem;
    color: var(--muted);
  }

  .speak-controls select,
  .speak-controls input[type="range"] {
    background: var(--surface-soft);
    border: 1px solid var(--panel-border);
    border-radius: 8px;
    color: var(--text);
    padding: 0.25rem 0.4rem;
    font-size: 0.78rem;
  }

  .speak-controls input[type="range"] {
    width: 70px;
    padding: 0;
    height: 4px;
    -webkit-appearance: none;
    appearance: none;
    background: var(--surface-soft);
    border-radius: 4px;
    cursor: pointer;
  }

  .speak-controls input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--primary);
    cursor: pointer;
  }

  .speak-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 0.7rem;
    border: 1px solid var(--panel-border);
    border-radius: 999px;
    background: var(--surface-soft);
    color: var(--text);
    font-size: 0.78rem;
    cursor: pointer;
    transition: background 0.2s;
  }

  .speak-btn:hover {
    background: rgba(139, 92, 246, 0.2);
  }

  .speak-btn--active {
    background: rgba(34, 197, 94, 0.2);
    border-color: rgba(34, 197, 94, 0.4);
    color: #86efac;
  }

  /* Chat messages */
  .speak-chat {
    flex: 1;
    overflow-y: auto;
    padding: 0.5rem;
    display: grid;
    gap: 0.25rem;
    align-content: flex-end;
  }

  .speak-msg {
    display: flex;
    gap: 0.5rem;
    padding: 0.4rem 0.6rem;
    border-radius: 10px;
    background: rgba(15, 23, 42, 0.6);
    font-size: 0.85rem;
    line-height: 1.4;
    word-break: break-word;
    animation: speak-msg-in 0.2s ease;
  }

  .speak-msg--speaking {
    background: rgba(139, 92, 246, 0.15);
    border-left: 2px solid var(--primary);
  }

  @keyframes speak-msg-in {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .speak-msg__nick {
    font-weight: 600;
    color: #c4b5fd;
    white-space: nowrap;
  }

  .speak-msg__text {
    color: var(--text);
  }

  .speak-msg__time {
    font-size: 0.7rem;
    color: rgba(148, 163, 184, 0.5);
    margin-left: auto;
    white-space: nowrap;
  }

  /* Empty state */
  .speak-empty {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    color: var(--muted);
    font-size: 0.9rem;
  }
</style>

<div class="speak-page">
  <div class="speak-status">
    <span class="speak-status__dot" id="wsDot"></span>
    <span id="wsStatus">Подключение...</span>
    <span style="margin-left: auto" id="msgCounter">0 сообщений</span>
  </div>

  <div class="speak-controls">
    <button class="speak-btn" id="toggleSpeech" title="Нажмите для запуска озвучки">
      🔇 Включить озвучку
    </button>

    <button class="speak-btn speak-btn--active" id="toggleNickname" title="Озвучивать никнейм перед сообщением">
      💬 Никнейм
    </button>

    <label>
      Голос
      <select id="voiceSelect"><option value="">Загрузка...</option></select>
    </label>

    <label>
      Скорость
      <input type="range" id="rateRange" min="0.5" max="2" step="0.1" value="1">
    </label>

    <label>
      Громкость
      <input type="range" id="volumeRange" min="0" max="1" step="0.1" value="1">
    </label>

    <button class="speak-btn" id="clearBtn" title="Очистить чат">
      🗑️ Очистить
    </button>
  </div>

  <div class="speak-chat" id="chatContainer">
    <div class="speak-empty" id="emptyState">Ожидание сообщений...</div>
  </div>
</div>

<script>
(function () {
  const MAX_MESSAGES = 100;
  const MAX_SPEECH_LENGTH = 300;
  const SPEECH_FRAGMENT_MAX = 180;
  const websocketPort = '{{websocketPort}}';
  const GOOGLE_VOICES = [
    { name: 'ru-RU-Standard-A', label: 'Google Standard A' },
    { name: 'ru-RU-Standard-B', label: 'Google Standard B' },
    { name: 'ru-RU-Standard-C', label: 'Google Standard C' },
    { name: 'ru-RU-Standard-D', label: 'Google Standard D' },
    { name: 'ru-RU-Standard-E', label: 'Google Standard E' }
  ];

  let speechEnabled = true;
  let speakNickname = true;
  let lastSpokenNick = null;
  let selectedVoice = 'ru-RU-Standard-E';

  const chatContainer = document.getElementById('chatContainer');
  const emptyState = document.getElementById('emptyState');
  const wsDot = document.getElementById('wsDot');
  const wsStatus = document.getElementById('wsStatus');
  const msgCounter = document.getElementById('msgCounter');
  const toggleSpeechBtn = document.getElementById('toggleSpeech');
  const toggleNicknameBtn = document.getElementById('toggleNickname');
  const voiceSelect = document.getElementById('voiceSelect');
  const rateRange = document.getElementById('rateRange');
  const volumeRange = document.getElementById('volumeRange');
  const clearBtn = document.getElementById('clearBtn');

  let messageCount = 0;
  let speechActivated = false;
  const pendingQueue = [];
  const speechQueue = [];
  let isSpeaking = false;
  let currentItem = null;
  let audioContext = null;
  let currentSource = null;
  let queueVersion = 0;

  const isOverlay = {{#if isOverlay}}true{{else}}false{{/if}};
  if (isOverlay) {
    setTimeout(() => {
      activateSpeech();
    }, 1000);
  }

  // --- Voices ---
  function loadVoices() {
    voiceSelect.innerHTML = '';
    GOOGLE_VOICES.forEach(voice => {
      const opt = document.createElement('option');
      opt.value = voice.name;
      opt.textContent = voice.label;
      voiceSelect.appendChild(opt);
    });
    voiceSelect.value = selectedVoice;
  }

  loadVoices();

  voiceSelect.addEventListener('change', () => {
    selectedVoice = voiceSelect.value || 'ru-RU-Standard-E';
  });

  // --- Speech ---
  function leftPad(value, length) {
    return ('0'.repeat(length) + value).slice(-length);
  }

  function getPitchByNickname(value) {
    let charNumbers = leftPad(value.charCodeAt(0).toString(), 3);
    let firstNumber = charNumbers.slice(0, 1);
    let secondNumbers = charNumbers.slice(1, 2);
    return +(firstNumber + '.' + secondNumbers);
  }

  function hasAudioContext() {
    return Boolean(window.AudioContext || window.webkitAudioContext);
  }

  function getAudioContext() {
    if (!audioContext) {
      const AudioContextClass = window.AudioContext || window.webkitAudioContext;
      if (!AudioContextClass) {
        throw new Error('Web Audio API is not supported');
      }
      audioContext = new AudioContextClass();
    }
    return audioContext;
  }

  async function unlockAudio() {
    const context = getAudioContext();
    if (context.state === 'suspended') {
      await context.resume();
    }

    const source = context.createBufferSource();
    const gain = context.createGain();
    gain.gain.value = 0;
    source.buffer = context.createBuffer(1, 1, context.sampleRate);
    source.connect(gain).connect(context.destination);
    source.start(0);
  }

  function base64ToArrayBuffer(base64) {
    const binary = atob(base64);
    const bytes = new Uint8Array(binary.length);
    for (let i = 0; i < binary.length; i++) {
      bytes[i] = binary.charCodeAt(i);
    }
    return bytes.buffer;
  }

  function splitSpeechText(text) {
    if (text.length <= SPEECH_FRAGMENT_MAX) return [text];

    const parts = [];
    const words = text.split(/\s+/);
    let buffer = '';

    words.forEach(word => {
      if (buffer && buffer.length + word.length + 1 > SPEECH_FRAGMENT_MAX) {
        parts.push(buffer);
        buffer = word;
        return;
      }
      buffer += (buffer ? ' ' : '') + word;
    });

    if (buffer) parts.push(buffer);
    return parts;
  }

  async function fetchSpeechBuffer(text, item) {
    const params = new URLSearchParams({
      text: text,
      pitch: String(item.pitch),
      rate: String(item.rate),
      voice: item.voice
    });
    const response = await fetch('/speech?' + params.toString());
    if (!response.ok) {
      throw new Error('Speech request failed: ' + response.status);
    }
    const data = await response.json();
    if (!data.audioContent) {
      throw new Error('Speech response has no audioContent');
    }
    const buffer = await getAudioContext().decodeAudioData(base64ToArrayBuffer(data.audioContent));
    return {
      buffer: buffer,
      playbackRate: data.playbackRate || 1
    };
  }

  function playBuffer(buffer, volume, playbackRate, token) {
    return new Promise(resolve => {
      const context = getAudioContext();
      const source = context.createBufferSource();
      const gain = context.createGain();

      source.buffer = buffer;
      source.playbackRate.value = playbackRate;
      gain.gain.value = volume;
      source.connect(gain).connect(context.destination);

      source.onended = () => {
        if (currentSource === source) currentSource = null;
        resolve();
      };

      currentSource = source;
      if (token !== queueVersion) {
        currentSource = null;
        resolve();
        return;
      }
      source.start(0);
    });
  }

  function speak(text, nickname) {
    if (!speechEnabled || !hasAudioContext()) return;
    if (text.length > MAX_SPEECH_LENGTH) {
      text = text.substring(0, MAX_SPEECH_LENGTH) + '...';
    }

    const texts = [];
    const nickChanged = lastSpokenNick !== nickname.toLowerCase();
    lastSpokenNick = nickname.toLowerCase();

    if (speakNickname && nickChanged) {
      texts.push(nickname);
    }
    texts.push(...splitSpeechText(text));

    speechQueue.push({
      texts: texts,
      rate: parseFloat(rateRange.value),
      volume: parseFloat(volumeRange.value),
      voice: selectedVoice,
      pitch: getPitchByNickname(nickname)
    });

    processQueue();
  }

  async function processQueue() {
    if (isSpeaking || speechQueue.length === 0) return;
    if (!speechEnabled || !speechActivated) return;

    isSpeaking = true;
    const token = queueVersion;

    try {
      while (speechEnabled && speechActivated && token === queueVersion && speechQueue.length > 0) {
        const item = speechQueue.shift();
        currentItem = item;

        for (const text of item.texts) {
          if (!speechEnabled || token !== queueVersion) return;
          try {
            const speechAudio = await fetchSpeechBuffer(text, item);
            if (!speechEnabled || token !== queueVersion) return;
            await playBuffer(speechAudio.buffer, item.volume, speechAudio.playbackRate, token);
          } catch (error) {
            console.error('speech audio error:', error);
          }
        }
      }
    } finally {
      isSpeaking = false;
      currentItem = null;
    }
  }

  // --- Activate speech (requires user gesture) ---
  function activateSpeech() {
    if (speechActivated) return;
    speechActivated = true;

    unlockAudio().catch(error => {
      console.error('audio unlock error:', error);
    });

    while (pendingQueue.length > 0) {
      const item = pendingQueue.shift();
      speak(item.text, item.nickname);
    }

    toggleSpeechBtn.classList.add('speak-btn--active');
    toggleSpeechBtn.textContent = '🔊 Озвучка';
  }

  // --- Toggle ---
  toggleSpeechBtn.addEventListener('click', () => {
    if (!speechActivated) {
      activateSpeech();
      return;
    }

    speechEnabled = !speechEnabled;
    toggleSpeechBtn.classList.toggle('speak-btn--active', speechEnabled);
    toggleSpeechBtn.textContent = speechEnabled ? '🔊 Озвучка' : '🔇 Озвучка';
    if (!speechEnabled) {
      queueVersion++;
      speechQueue.length = 0;
      currentItem = null;
      isSpeaking = false;
      if (currentSource) {
        currentSource.stop();
        currentSource = null;
      }
    } else {
      processQueue();
    }
  });

  toggleNicknameBtn.addEventListener('click', () => {
    speakNickname = !speakNickname;
    toggleNicknameBtn.classList.toggle('speak-btn--active', speakNickname);
  });

  // --- Clear ---
  clearBtn.addEventListener('click', () => {
    chatContainer.innerHTML = '';
    messageCount = 0;
    pendingQueue.length = 0;
    speechQueue.length = 0;
    currentItem = null;
    isSpeaking = false;
    queueVersion++;
    if (currentSource) {
      currentSource.stop();
      currentSource = null;
    }
    updateCounter();
    emptyState.style.display = '';
    chatContainer.appendChild(emptyState);
    lastSpokenNick = null;
  });

  // --- Messages ---
  function updateCounter() {
    msgCounter.textContent = messageCount + ' сообщени' + pluralize(messageCount);
  }

  function pluralize(n) {
    const abs = Math.abs(n) % 100;
    const last = abs % 10;
    if (abs > 10 && abs < 20) return 'й';
    if (last > 1 && last < 5) return 'я';
    if (last === 1) return 'е';
    return 'й';
  }

  function formatTime(ts) {
    const d = new Date(ts);
    return d.toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' });
  }

  function addMessage(nickname, message, timestamp, isSub, shouldSpeak = true) {
    if (emptyState.parentNode) emptyState.style.display = 'none';

    messageCount++;
    updateCounter();

    const el = document.createElement('div');
    el.className = 'speak-msg';
    el.dataset.nickname = nickname;

    const time = formatTime(timestamp || Date.now());

    el.innerHTML =
      '<span class="speak-msg__nick">' + escapeHtml(nickname) + '</span>' +
      '<span class="speak-msg__text">' + escapeHtml(message) + '</span>' +
      '<span class="speak-msg__time">' + time + '</span>';

    chatContainer.appendChild(el);

    // Remove oldest if over limit
    while (chatContainer.children.length > MAX_MESSAGES) {
      chatContainer.removeChild(chatContainer.firstChild);
    }

    // Auto-scroll
    chatContainer.scrollTop = chatContainer.scrollHeight;

    // Speak
    if (shouldSpeak && !message.startsWith('!')) {
      if (!speechActivated) {
        pendingQueue.push({ text: message, nickname: nickname });
        el.classList.add('speak-msg--speaking');
      } else {
        speak(message, nickname);
        el.classList.add('speak-msg--speaking');
      }
    }
  }

  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  // --- Load recent messages ---
  fetch('/api/chat/recent?limit=50')
    .then(r => r.json())
    .then(messages => {
      if (!Array.isArray(messages) || messages.length === 0) return;
      messages.forEach(m => {
        addMessage(
          m.displayName || m.user,
          m.message,
          m.createdAt ? new Date(m.createdAt).getTime() : Date.now(),
          false,
          false
        );
      });
    })
    .catch(() => {});

  // --- WebSocket ---
  function playAudio(audioName) {
    let audio = new Audio('/audio/' + audioName);
    audio.volume = 0.5;
    audio.play();
  }

  const wsProtocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
  const wsUrl = window.location.protocol === 'https:'
    ? wsProtocol + '//' + window.location.host + '/ws'
    : 'ws://' + window.location.hostname + ':' + websocketPort;
  const ws = new WebSocket(wsUrl);

  ws.addEventListener('open', () => {
    wsDot.classList.add('speak-status__dot--connected');
    wsStatus.textContent = 'Подключено';
  });

  ws.addEventListener('close', () => {
    wsDot.classList.remove('speak-status__dot--connected');
    wsStatus.textContent = 'Отключено';
  });

  ws.addEventListener('error', () => {
    wsDot.classList.remove('speak-status__dot--connected');
    wsStatus.textContent = 'Ошибка соединения';
  });

  ws.addEventListener('message', event => {
    try {
      const data = JSON.parse(event.data);

      if (data.type === 'chat') {
        addMessage(data.nickname, data.message, data.timestamp, data.isSub);
      }

      if (data.type === 'speech') {
        if (!speechActivated) {
          pendingQueue.push({ text: data.text, nickname: data.nickname });
        } else {
          speak(data.text, data.nickname);
        }
      }

      if (data.type === 'audio') {
        playAudio(data.name);
      }
    } catch (e) {
      console.error('speak ws error:', e);
    }
  });
})();
</script>
