{{! ── Hero ── }}
<section class="hero">
  <div class="hero__bg"></div>
  <div class="container hero__inner">
    <div class="hero__left">
      <div class="status-pill status-pill--{{stream.status}} hero__status">
        {{#if (eq stream.status 'online')}}
          <span class="live-dot"></span> {{stream.statusLabel}}
        {{else}}
          {{stream.statusLabel}}
        {{/if}}
      </div>
      <h1 class="hero__title">{{profile.name}}</h1>
      <p class="hero__tagline">{{profile.tagline}}</p>
      <p class="hero__desc">{{profile.description}}</p>
      <div class="hero__actions">
        {{#if (eq stream.status 'online')}}
          <a class="btn btn--primary btn--lg" href="https://www.twitch.tv/{{profile.handle}}" target="_blank" rel="noreferrer">
            ▶ Смотреть стрим
          </a>
        {{else}}
          <a class="btn btn--primary btn--lg" href="{{profile.supportLinks.primary.url}}" target="_blank" rel="noreferrer">
            ⭐ Поддержать на Boosty
          </a>
        {{/if}}
        <a class="btn btn--ghost btn--lg" href="#player">
          Плеер и чат
        </a>
      </div>
    </div>
    <div class="hero__right">
      {{#if stream.thumbnailUrl}}
        <div class="hero__preview">
          <img src="{{stream.thumbnailUrl}}" alt="Превью стрима {{profile.name}}" />
          {{#if (eq stream.status 'online')}}
            <span class="hero__preview-badge">LIVE</span>
          {{/if}}
        </div>
      {{else}}
        <div class="hero__card-info">
          {{#if stream.title}}
            <h3>{{stream.title}}</h3>
          {{/if}}
          <dl class="hero__dl">
            {{#if (ne stream.gameName '—')}}
              <div><dt>🎮 Категория</dt><dd>{{stream.gameName}}</dd></div>
            {{/if}}
            {{#if (ne stream.uptimeLabel '—')}}
              <div><dt>⏱ Длительность</dt><dd>{{stream.uptimeLabel}}</dd></div>
            {{/if}}
            {{#if (ne stream.viewerCountLabel '—')}}
              <div><dt>👁 Зрителей</dt><dd>{{stream.viewerCountLabel}}</dd></div>
            {{/if}}
          </dl>
        </div>
      {{/if}}
    </div>
  </div>
</section>

{{! ── Quick stats strip ── }}
<section class="quick-stats container">
  {{#each summaryCards}}
    <div class="quick-stat quick-stat--{{accent}}">
      <span class="quick-stat__value">{{value}}</span>
      <span class="quick-stat__label">{{label}}</span>
    </div>
  {{/each}}
</section>

{{! ── Player + Chat ── }}
<section class="container section-block" id="player">
  <div class="section-head">
    <h2 class="section-title">📺 Плеер и чат</h2>
    <a class="section-link" href="https://www.twitch.tv/{{profile.handle}}" target="_blank" rel="noreferrer">
      Открыть на Twitch →
    </a>
  </div>
  <div class="player-grid">
    <div class="player-frame">
      <iframe
        src="{{profile.embeds.playerUrl}}"
        allowfullscreen="true"
        loading="lazy"
        title="Twitch player {{profile.name}}"
      ></iframe>
    </div>
    <div class="chat-frame">
      <iframe
        src="{{profile.embeds.chatUrl}}"
        loading="lazy"
        title="Twitch chat {{profile.name}}"
      ></iframe>
    </div>
  </div>
</section>

{{! ── Support / CTA ── }}
<section class="container section-block">
  <div class="section-head">
    <h2 class="section-title">💛 Поддержать канал</h2>
  </div>
  <div class="support-grid">
    <a class="support-card support-card--boosty" href="{{profile.supportLinks.primary.url}}" target="_blank" rel="noreferrer">
      <div class="support-card__icon">⭐</div>
      <h3>{{profile.supportLinks.primary.label}}</h3>
      <p>{{profile.supportLinks.primary.description}}</p>
      <span class="support-card__cta">Перейти →</span>
    </a>
    <a class="support-card support-card--donate" href="{{profile.supportLinks.secondary.url}}" target="_blank" rel="noreferrer">
      <div class="support-card__icon">💸</div>
      <h3>{{profile.supportLinks.secondary.label}}</h3>
      <p>{{profile.supportLinks.secondary.description}}</p>
      <span class="support-card__cta">Перейти →</span>
    </a>
  </div>
</section>

{{! ── Social links ── }}
<section class="container section-block">
  <div class="section-head">
    <h2 class="section-title">🔗 Социальные сети</h2>
  </div>
  <div class="social-grid">
    {{#each profile.links}}
      <a class="social-card social-card--{{key}}" href="{{url}}" target="_blank" rel="noreferrer">
        <div class="social-card__top">
          <span class="social-card__icon social-icon social-icon--{{key}}" aria-hidden="true">
            {{#if (eq key 'twitch')}}
              <img src="https://cdn.simpleicons.org/twitch/9146FF" alt="" loading="lazy" />
            {{/if}}
            {{#if (eq key 'boosty')}}
              <img src="https://cdn.simpleicons.org/boosty/F15F2C" alt="" loading="lazy" />
            {{/if}}
            {{#if (eq key 'youtube')}}
              <img src="https://cdn.simpleicons.org/youtube/FF0000" alt="" loading="lazy" />
            {{/if}}
            {{#if (eq key 'telegram')}}
              <img src="https://cdn.simpleicons.org/telegram/26A5E4" alt="" loading="lazy" />
            {{/if}}
            {{#if (eq key 'discord')}}
              <img src="https://cdn.simpleicons.org/discord/5865F2" alt="" loading="lazy" />
            {{/if}}
            {{#if (eq key 'tiktok')}}
              <img src="https://cdn.simpleicons.org/tiktok/FFFFFF" alt="" loading="lazy" />
            {{/if}}
            {{#if (eq key 'donate')}}
              <img src="/assets/img/donationalerts.svg" alt="" loading="lazy" />
            {{/if}}
          </span>
        </div>
        <strong>{{label}}</strong>
        <span>{{description}}</span>
      </a>
    {{/each}}
  </div>
</section>

{{! ── Community ── }}
<section class="container section-block">
  <div class="section-head">
    <h2 class="section-title">💬 Комьюнити</h2>
  </div>
  <div class="community-grid">
    <div class="panel">
      <div class="panel__head">
        <h3>Последние сообщения чата</h3>
      </div>
      {{#if chatStats.hasRecentMessages}}
        <ul class="msg-list">
          {{#each chatStats.recentMessages}}
            <li class="msg-item">
              <div class="msg-item__head">
                <strong>{{displayName}}</strong>
                <span>{{createdAtLabel}}</span>
              </div>
              <p>{{text}}</p>
            </li>
          {{/each}}
        </ul>
      {{else}}
        <p class="empty">Чат пока пуст. Загляни во время стрима!</p>
      {{/if}}
    </div>
    <div class="panel">
      <div class="panel__head">
        <h3>🏆 Топ чаттеров за 24 часа</h3>
        <a class="panel__link" href="/stats">Вся статистика →</a>
      </div>
      {{#if chatStats.hasTopChatters}}
        <ol class="leaderboard">
          {{#each chatStats.topChatters}}
            {{#if (lt position 6)}}
              <li class="leaderboard__item">
                <span class="leaderboard__pos leaderboard__pos--{{position}}">{{position}}</span>
                <div class="leaderboard__info">
                  <strong>{{displayName}}</strong>
                  <span>{{messagesCountLabel}} сообщений</span>
                </div>
              </li>
            {{/if}}
          {{/each}}
        </ol>
      {{else}}
        <p class="empty">Рейтинг появится, когда чат оживёт!</p>
      {{/if}}
    </div>
  </div>
</section>

{{#if stream.error}}
  <section class="container">
    <p class="notice">{{stream.error}}</p>
  </section>
{{/if}}
