<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />
    <title>{{pageTitle}}</title>
    <meta name="description" content="{{pageDescription}}" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="stylesheet" href="/css/site.css" />
  </head>
  <body class="site-body page-{{currentPage}}">
    <div class="site-shell">
      <header class="site-header">
        <div class="site-header__inner container">
          <a class="site-logo" href="/">NGLZZZ</a>

          <nav class="site-nav" aria-label="Основная навигация">
            {{#each navigation}}
              <a class="site-nav__link {{#if isActive}}is-active{{/if}}" href="{{href}}">
                {{label}}
              </a>
            {{/each}}
          </nav>
        </div>
      </header>

      <main class="site-main">
        {{{body}}}
      </main>

      <footer class="site-footer">
        <div class="container site-footer__inner">
          <div>
            <strong>NGLZZZ mini-site</strong>
            <p>Поверх существующего Twitch-бота, Mongo-логов и Docker-инфраструктуры.</p>
          </div>
          <div class="site-footer__meta">
            <span>Обновлено: {{generatedAtLabel}}</span>
            <a href="/api/streamer/stats">JSON API</a>
          </div>
        </div>
      </footer>
    </div>

    <script src="/js/site.js" defer></script>
  </body>
</html>
