<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#07060f" />
    <title>{{pageTitle}}</title>
    <meta name="description" content="{{pageDescription}}" />
    <meta property="og:title" content="{{pageTitle}}" />
    <meta property="og:description" content="{{pageDescription}}" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="stylesheet" href="/css/site.css" />
  </head>
  <body class="site-body page-{{currentPage}}">
    <div class="site-shell">
      <header class="site-header" data-header>
        <div class="site-header__inner container">
          <a class="site-logo" href="/">
            <img class="site-logo__image" src="/assets/img/logo.png" alt="" />
            <span>NGLZZZ</span>
          </a>

          <nav class="site-nav" data-nav aria-label="Основная навигация">
            {{#each navigation}}
              <a class="site-nav__link {{#if isActive}}is-active{{/if}}" href="{{href}}">
                {{label}}
              </a>
            {{/each}}
          </nav>

          <button class="nav-toggle" data-nav-toggle aria-label="Открыть меню" aria-expanded="false">
            <span></span>
            <span></span>
            <span></span>
          </button>
        </div>
      </header>

      <main class="site-main">
        {{{body}}}
      </main>

      <footer class="site-footer">
        <div class="container site-footer__inner">
          <div class="site-footer__brand">
            <strong>NGLZZZ</strong>
            <p>Спасибо за поддержку! Увидимся на стриме 💜</p>
          </div>
          <div class="site-footer__links">
            <a href="https://www.twitch.tv/nglzzz" target="_blank" rel="noreferrer">Twitch</a>
            <a href="https://boosty.to/nglzzz" target="_blank" rel="noreferrer">Boosty</a>
            <a href="https://www.youtube.com/@nglzzz" target="_blank" rel="noreferrer">YouTube</a>
            <a href="https://t.me/nglzzzTV" target="_blank" rel="noreferrer">Telegram</a>
            <a href="https://discord.gg/uKCbdCGwTb" target="_blank" rel="noreferrer">Discord</a>
          </div>
        </div>
      </footer>
    </div>

    <script src="/js/site.js" defer></script>
  </body>
</html>
